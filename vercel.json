{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/tickets/verify/:token", "destination": "/ticket-verify.html" }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 10
    }
  }
}
