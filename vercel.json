{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/server" }
  ],
  "functions": {
    "api/server.js": {
      "maxDuration": 10,
      "includeFiles": [
        "*.html",
        "assets/**",
        "config/**"
      ]
    }
  }
}
